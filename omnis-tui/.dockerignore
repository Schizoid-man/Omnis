src-tauri/gen/android/app/src/main/jniLibs/
src-tauri/gen/android/.gradle/
src-tauri/gen/android/build/

# Node / Next.js
web/node_modules/
web/.next/
web/dist/
web/out/

# Docker build outputs
out/

# macOS SDK (never commit, not needed for Android)
sdk/
