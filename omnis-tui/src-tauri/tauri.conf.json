{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omnis Desktop",
  "version": "0.1.0",
  "identifier": "com.omnis.desktop",
  "build": {
    "frontendDist": "../web/out",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm --prefix ../web run dev",
    "beforeBuildCommand": "npm --prefix ../web run build"
  },
  "app": {
    "windows": [
      {
        "title": "Omnis Desktop",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
